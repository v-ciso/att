# ── Database (Supabase PostgreSQL) ──────────────────────────────────────────
# From Supabase: Project Settings → Database → Connection string.
# DATABASE_URL  = the POOLED connection (port 6543, add ?pgbouncer=true)
# DIRECT_URL    = the DIRECT connection (port 5432) — used only for migrations
DATABASE_URL="postgresql://postgres.<project-ref>:<password>@aws-0-<region>.pooler.supabase.com:6543/postgres?pgbouncer=true"
DIRECT_URL="postgresql://postgres.<project-ref>:<password>@aws-0-<region>.pooler.supabase.com:5432/postgres"

# ── NextAuth ────────────────────────────────────────────────────────────────
# NEXTAUTH_URL: the app's public URL (production = your subdomain)
# NEXTAUTH_SECRET: signs the session JWT. Must be >=32 chars and must not start
# with "demo-" — production refuses to boot otherwise, because a shared or
# guessable value here lets anyone mint an OWNER session.
#   openssl rand -base64 32
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="generate-with-openssl-rand-base64-32"

# ── Signup ──────────────────────────────────────────────────────────────────
# Self-serve signup creates a whole new tenant with an OWNER account, so it is
# CLOSED while this is unset (/api/auth/register returns 403). Set it only when
# you want to hand a new customer a signup link, and rotate it after onboarding.
# SIGNUP_INVITE_CODE=""

# ── App ─────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# ── Email (optional, later — magic link sign-in via Resend) ─────────────────
RESEND_API_KEY="re_..."
